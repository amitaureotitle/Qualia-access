BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Qualia credentials
QUALIA_USERNAME=
QUALIA_PASSWORD=
QUALIA_BASE_URL=https://aureotitle.qualia.io/

# Persistent browser context — stores Qualia login across sessions
# Create once with: npx ts-node -e "import('./src/browserbase').then(m => m.createContext().then(console.log))"
QUALIA_CONTEXT_ID=
QUALIA_TOTP_SECRET=

# API server (src/server.ts)
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUALIA_API_KEY=
API_PORT=3001

# WhatsApp bulk sender (src/scripts/whatsapp/send-bulk.ts)
WHATSAPP_SPREADSHEET_ID=        # Google Sheet ID (or pass as first CLI arg)
WHATSAPP_SHEET_NAME=Sheet1      # Tab name
WHATSAPP_PHONE_COLUMN=A         # Column letter for phone numbers
WHATSAPP_MESSAGE_COLUMN=B       # Column letter for personalized messages
WHATSAPP_START_ROW=2            # First data row (2 = skip header row)
WHATSAPP_DELAY_MS=4000          # Delay between sends in ms